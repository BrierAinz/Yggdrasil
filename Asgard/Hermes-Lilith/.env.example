# Lilith Environment Variables
# =============================
# Copiar este archivo como .env y rellenar los valores.
# NUNCA hacer commit del archivo .env real.

# LM Studio (local)
LILITH_LM_URL=http://localhost:1234/v1
LILITH_MODEL=auto

# Kimi / Moonshot API (remote fallback)
KIMI_API_KEY=

# Provider: "auto" (probar LM Studio primero, luego Kimi)
# O forzar: "lm_studio", "kimi"
LILITH_PROVIDER=auto
