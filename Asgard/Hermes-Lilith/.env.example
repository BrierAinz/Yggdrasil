# Lilith Environment Configuration
# Copia este archivo a .env y rellena los valores

# ─── LLM (LM Studio) ─────────────────────────────────────────────
LM_STUDIO_URL=http://localhost:1234/v1
MODEL=auto
TEMPERATURE=0.7
MAX_TOKENS=4096

# ─── Telegram Bot ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_token_aqui
TELEGRAM_OWNER_CHAT_ID=tu_chat_id_aqui

# ─── Gateway ─────────────────────────────────────────────────────
GATEWAY_HOST=localhost
GATEWAY_PORT=8000

# ─── Optional: APIs externas ─────────────────────────────────────
# OPENWEATHER_API_KEY=
# NEWS_API_KEY=
