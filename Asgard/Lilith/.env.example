# Lilith — variables de entorno raíz
# Copia a .env y rellena. NUNCA subas .env al repo.
# El backend carga este archivo automáticamente al arrancar.

# ── Seguridad interna ──────────────────────────────────────────────────────────
# Token compartido entre el backend y todos los bots (Discord, Telegram, VSCode)
LILITH_INTERNAL_TOKEN=

# ── LLM APIs ──────────────────────────────────────────────────────────────────
GROK_API_KEY=            # xAI Grok (agente Eva)
KIMI_API_KEY=            # Moonshot Kimi (agentes Lucifer y Odín)
VENICE_API_KEY=          # Venice AI (opcional)
OPENROUTER_API_KEY=      # OpenRouter (agente Crystal — Discord público)

# ── MuninnDB ──────────────────────────────────────────────────────────────────
MUNINN_TOKEN=            # Token de API de MuninnDB (ver Core/Config/muninn.json)

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=           # Token del bot de Discord
DISCORD_GUILD_ID=        # ID del servidor para sync inmediato de slash commands
LILITH_HOME_CATEGORY_ID= # ID de la categoría donde vive el canal de Lilith
LILITH_BOT_ID=           # ID de la aplicación del bot
LILITH_MAIN_CHANNEL_ID=  # Canal principal donde Lilith responde
AINZ_DISCORD_ID=         # Discord ID del usuario Ainz (restricciones especiales)
DISCORD_PC_ENABLED=false # Deshabilitar control de PC desde Discord

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=      # Token del bot de Telegram (@BotFather)
TELEGRAM_OWNER_CHAT_ID=  # Chat ID del owner (dejar vacío = sin restricción)

# ── Extensión VSCode ──────────────────────────────────────────────────────────
LILITH_VSCODE_TOKEN=     # Token de autenticación para la extensión VS Code

# ── General ───────────────────────────────────────────────────────────────────
LILITH_API_URL=http://127.0.0.1:8000  # URL base de la API (usada por bots)
