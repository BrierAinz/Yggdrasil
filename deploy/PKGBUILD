# Maintainer: BrierStudios <brier@brierstudios.com>
pkgname=lilith-agent
pkgver=4.0.0
pkgrel=1
pkgdesc="Dark Goddess of Yggdrasil Digital — Full coding CLI agent"
arch=('any')
url="https://github.com/BrierStudios/lilith-agent"
license=('MIT')
depends=('python' 'python-requests' 'python-rich')
makedepends=('python-build' 'python-installer' 'python-hatchling')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/BrierStudios/${pkgname}/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "${pkgname}-${pkgver}"
    python -m build --wheel --no-isolation
}

package() {
    cd "${pkgname}-${pkgver}"
    python -m installer --destdir="$pkgdir" dist/*.whl
    install -Dm644 LILITH_README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
