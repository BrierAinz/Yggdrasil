# ──────────────────────────────────────────────────────────────────────
# YggdrasilForge — Environment Configuration
# Copy this to .env and modify as needed
# ──────────────────────────────────────────────────────────────────────

# Server
HOST=0.0.0.0
PORT=8081
DEBUG=false

# Blender MCP Addon (port 9897, NOT default 9876!)
# On WSL2: use Windows host IP or 0.0.0.0 if addon is configured accordingly
BLENDER_MCP_URL=http://127.0.0.1:9897

# AI Services (via Blender MCP — no direct API keys needed)
HUNYUAN3D_ENABLED=true
RODIN_ENABLED=true
POLYHAVEN_ENABLED=true
SKETCHFAB_ENABLED=true

# Generation polling
POLL_INTERVAL_SECONDS=5
POLL_TIMEOUT_SECONDS=600

# Data directories (defaults to ./data/ if not set)
# DATA_DIR=/mnt/d/Proyectos/Yggdrasil/Alfheim/YggdrasilForge/data
# DB_PATH=
# OUTPUT_DIR=

# CORS origins (comma-separated)
CORS_ORIGINS=["http://localhost:5174","http://localhost:3000"]

# YggdrasilStudio bridge
STUDIO_URL=http://localhost:8080
