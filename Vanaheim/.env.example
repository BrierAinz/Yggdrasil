# Vanaheim Environment Configuration
# Copiar a .env y completar los valores

# Puerto del servicio
VANAHEIM_PORT=8001
VANAHEIM_HOST=0.0.0.0

# URL de Asgard/MuninnDB
MUNINN_URL=http://localhost:8000

# API Keys
VENICE_API_KEY=tu_api_key_de_venice
GROK_API_KEY=tu_api_key_de_grok
KIMI_API_KEY=tu_api_key_de_kimi
CRYSTAL_KIMI_API_KEY=tu_api_key_de_kimi_para_crystal

# Ollama (opcional, por defecto localhost:11434)
OLLAMA_HOST=http://localhost:11434
